# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional: absolute API origin. Leave unset for same-origin (browser calls /api on the current host).
# Dev: only if Vite and API run on different ports, e.g. VITE_API_ORIGIN=http://localhost:3000
# Vercel: set to your deployed Node/API base URL if the API is hosted separately (no trailing slash).
# VITE_API_ORIGIN=https://your-api.example.com

# Supabase Configuration
# Server also reads SUPABASE_URL (or falls back to VITE_SUPABASE_URL) for Node.
SUPABASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server only — required for POST /api/groups and membership sync (bypasses RLS). Same project as URL/anon key.
# After setting, restart the dev server; logs must show: USING SERVICE ROLE: true
SUPABASE_SERVICE_ROLE_KEY=

# Agora Configuration
VITE_AGORA_APP_ID=

# Stripe — coin purchases (Checkout + webhook).
# Client (Vite): NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is preferred; VITE_STRIPE_PUBLIC_KEY still works.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_publishable_key
# VITE_STRIPE_PUBLIC_KEY=your_public_key
# Server only (set in Vercel Project → Environment Variables; never commit real values).
STRIPE_SECRET_KEY=your_secret_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret
# Optional: where Stripe redirects after pay/cancel (defaults to request Origin or http://localhost:5173)
# CLIENT_URL=https://your-app.example.com
